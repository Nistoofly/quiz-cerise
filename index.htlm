<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Quiz Cerise — Nistoofly</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;600;700;800&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'DM Sans', Arial, sans-serif;
      background: #F5DCC8;
      min-height: 100vh;
      display: flex;
      align-items: flex-start;
      justify-content: center;
      padding: 48px 20px 64px;
    }
    #app { width: 100%; max-width: 520px; }

    /* QUIZ */
    .progress-label {
      font-size: 13px; font-weight: 700; letter-spacing: 1.5px;
      text-transform: uppercase; color: #8B1E3F; margin-bottom: 14px;
    }
    .progress-track {
      height: 6px; background: rgba(139,30,63,0.12);
      border-radius: 4px; overflow: hidden; margin-bottom: 40px;
    }
    .progress-fill {
      height: 100%; background: #8B1E3F; border-radius: 4px;
      transition: width 0.4s ease;
    }
    .question-title {
      font-size: clamp(26px, 6vw, 34px); color: #1C1A18; font-weight: 800;
      line-height: 1.25; margin-bottom: 16px; letter-spacing: -0.5px;
      text-align: center;
    }
    .question-sub {
      text-align: center; color: #6B5A4E; font-size: 16px; margin-bottom: 36px;
    }
    .options { display: flex; flex-direction: column; gap: 16px; }
    .option-btn {
      background: #8B1E3F; color: #fff; border: none; border-radius: 16px;
      padding: 26px 28px; text-align: left; cursor: pointer;
      font-size: 17px; font-family: 'DM Sans', Arial, sans-serif;
      font-weight: 700; line-height: 1.4;
      transition: all 0.2s;
      box-shadow: 0 6px 20px rgba(139,30,63,0.18);
    }
    .option-btn:hover { transform: scale(1.01); }
    .option-btn.faded { opacity: 0.55; }
    .option-btn.selected { transform: scale(1.015); }

    /* RÉSULTAT */
    .profile-badge {
      display: inline-block; background: rgba(139,30,63,0.1);
      color: #8B1E3F; font-size: 11px; font-weight: 700;
      letter-spacing: 2.5px; text-transform: uppercase;
      padding: 6px 16px; border-radius: 20px; margin-bottom: 16px;
    }
    .profile-title {
      font-size: clamp(28px, 6vw, 36px); font-weight: 700;
      color: #1C1A18; margin-bottom: 12px; letter-spacing: -0.5px;
    }
    .profile-tagline {
      font-size: 16px; color: #8B1E3F; font-weight: 600;
      line-height: 1.4; margin-bottom: 40px;
    }
    .result-card {
      background: #fff; border-radius: 20px; padding: 36px 32px;
      box-shadow: 0 4px 24px rgba(139,30,63,0.07); margin-bottom: 16px;
    }
    .result-card-dark {
      background: #8B1E3F; border-radius: 20px;
      padding: 36px 32px; margin-bottom: 16px;
    }
    .card-label {
      font-size: 11px; font-weight: 700; letter-spacing: 2.5px;
      text-transform: uppercase; color: #8B1E3F; margin-bottom: 20px;
    }
    .card-label-orange {
      font-size: 11px; font-weight: 700; letter-spacing: 2.5px;
      text-transform: uppercase; color: #E8622A; margin-bottom: 16px;
    }
    .card-desc { font-size: 15px; color: #1C1A18; line-height: 1.75; margin-bottom: 24px; }
    .card-bonne-nouvelle {
      border-left: 3px solid #E8622A; padding-left: 16px;
      font-size: 15px; font-weight: 600; color: #1C1A18; line-height: 1.65;
    }
    .priority-item {
      display: flex; align-items: flex-start; gap: 12px;
      font-size: 15px; color: #1C1A18; line-height: 1.5; margin-bottom: 12px;
    }
    .priority-check { color: #E8622A; font-weight: 700; flex-shrink: 0; font-size: 16px; }
    .objectif-text {
      font-size: 16px; font-weight: 700; color: #FDFCFB;
      line-height: 1.55; margin-bottom: 24px;
    }
    .suite-divider {
      border-top: 1px solid rgba(255,255,255,0.1); padding-top: 20px;
    }
    .suite-text {
      font-size: 14px; color: rgba(255,255,255,0.65);
      line-height: 1.65; font-style: italic;
    }
    .restart-btn {
      background: none; border: none; color: #6B5A4E;
      font-size: 13px; font-family: 'DM Sans', Arial, sans-serif;
      cursor: pointer; text-decoration: underline; display: block;
      margin: 8px auto 0;
    }
    .footer-sig {
      text-align: center; color: #C4A8B0; font-size: 12px; margin-top: 24px;
    }
  </style>
</head>
<body>
<div id="app"></div>

<script>
  const C = {
    cerise: "#8B1E3F",
    orange: "#E8622A",
  };

  const questions = [
    {
      question: "Si ton salaire s'arrêtait demain, il se passe quoi ?",
      options: [
        { text: "Je suis en difficulté immédiatement", points: 0 },
        { text: "Je tiens quelques semaines, pas plus", points: 1 },
        { text: "Je tiens quelques mois", points: 2 },
        { text: "Je suis sereine — j'ai un coussin solide", points: 3 },
      ],
    },
    {
      question: "Si ta machine à laver tombe en panne demain, comment tu réagis ?",
      options: [
        { text: "Panique totale — j'ai aucune réserve pour ça", points: 0 },
        { text: "Je me débrouille mais ça va faire mal", points: 1 },
        { text: "J'ai un peu de côté, ça passe", points: 2 },
        { text: "C'est prévu — j'ai un fonds pour les imprévus", points: 3 },
      ],
    },
    {
      question: "Quand une dépense imprévue arrive…",
      options: [
        { text: "Stress total — j'ai rien en réserve", points: 0 },
        { text: "Je me débrouille mais ça fait mal", points: 1 },
        { text: "J'utilise mon épargne, ça va", points: 2 },
        { text: "C'est déjà prévu dans mon budget", points: 3 },
      ],
    },
    {
      question: "Pourquoi tu veux plus d'argent de côté ?",
      options: [
        { text: "Sortir la tête de l'eau", points: 0 },
        { text: "Me sentir enfin en sécurité", points: 1 },
        { text: "Financer un projet précis", points: 2 },
        { text: "Gagner en liberté et en choix", points: 3 },
      ],
    },
    {
      question: "Ton objectif principal aujourd'hui c'est…",
      options: [
        { text: "Arrêter les découverts", points: 0 },
        { text: "Construire mon premier coussin", points: 1 },
        { text: "Financer un projet concret", points: 2 },
        { text: "Me sentir libre financièrement", points: 3 },
      ],
    },
  ];

  const profiles = [
    {
      range: [0, 5],
      title: "Cerise Bourgeon",
      tagline: "Tu pars de zéro — et c'est exactement là qu'on commence.",
      description: "Tu n'as pas encore de filet. Chaque mois ressemble au précédent — l'argent part, il ne reste rien, et tu ne sais pas vraiment pourquoi. Ce n'est pas un manque de volonté. C'est l'absence d'un système.",
      bonneNouvelle: "Tu n'as pas besoin de gagner plus pour changer ça. Tu as besoin d'un point de départ simple, clair, et atteignable dès ce mois-ci.",
      priorities: ["Stopper les fuites invisibles", "Poser une première réserve, même petite", "Reprendre le contrôle de ce qui rentre et ce qui sort"],
      objectif: "Mettre 500€ de côté sans te priver. Juste avoir un premier coussin qui dit — je suis là.",
      suite: "Tu recevras dans mes mails, palier par palier, les méthodes concrètes pour y arriver.",
    },
    {
      range: [6, 9],
      title: "Cerise Fleurie",
      tagline: "Tu veux avancer — ton argent manque encore de direction.",
      description: "Tu n'es pas en difficulté. Tu n'es pas non plus totalement sereine. Tu sais qu'il faudrait mettre certaines choses en place mais tu ne sais pas toujours par quoi commencer.",
      bonneNouvelle: "Tu n'as pas besoin de gagner plus pour progresser. Tu as surtout besoin d'un système simple que tu peux suivre sans y penser chaque semaine.",
      priorities: ["Créer une réserve de sécurité", "Identifier les fuites d'argent", "Mettre en place une épargne automatique"],
      objectif: "Construire ton premier coussin de sécurité. Quand un imprévu arrive, tu dois pouvoir respirer sans stress.",
      suite: "Tu recevras dans mes mails, palier par palier, les méthodes concrètes pour y arriver.",
    },
    {
      range: [10, 12],
      title: "Cerise Mûre",
      tagline: "Tu as les bases — maintenant il te faut la solidité.",
      description: "Tu épargnes déjà. Mais ton système tient à un fil — un mois irrégulier suffit à tout dérégler. Tu as la volonté. Il te manque le cadre qui tient même quand tu n'as pas l'énergie.",
      bonneNouvelle: "Le vrai sujet pour toi ce n'est plus la motivation. C'est l'automatisation. Un système qui tourne sans toi, même les mois difficiles.",
      priorities: ["Automatiser pour ne plus dépendre de ta motivation", "Résister aux mois difficiles sans tout effacer", "Atteindre un premier palier chiffré et le tenir"],
      objectif: "Construire un coussin de 3 mois de dépenses. Peu importe combien de temps ça prend.",
      suite: "Tu recevras dans mes mails, palier par palier, les méthodes concrètes pour y arriver.",
    },
    {
      range: [13, 15],
      title: "Cerise Royale",
      tagline: "Tu gères — il te reste des gains cachés à aller chercher.",
      description: "Tu gères. Ton argent a une direction. Mais il reste des fuites que tu n'as pas encore identifiées, et un palier suivant que tu n'as pas encore franchi.",
      bonneNouvelle: "Tu n'as pas besoin de repartir de zéro. Tu as besoin d'optimiser ce qui existe déjà et de définir clairement la prochaine étape.",
      priorities: ["Identifier ce qui fuit encore discrètement", "Définir ton prochain objectif chiffré", "Faire travailler ton argent au lieu de le laisser dormir"],
      objectif: "Dépasser ton plafond actuel et poser une stratégie long terme.",
      suite: "Tu recevras dans mes mails, palier par palier, les méthodes concrètes pour y arriver.",
    },
  ];

  function getProfile(score) {
    return profiles.find(p => score >= p.range[0] && score <= p.range[1]) || profiles[3];
  }

  // ─── STATE ───────────────────────────────────────────────
  let state = { step: "quiz", current: 0, answers: [], selected: null, score: 0 };

  function setState(updates) {
    state = { ...state, ...updates };
    render();
  }

  function handleSelect(points, idx) {
    if (state.selected !== null) return;
    setState({ selected: idx });
    setTimeout(() => {
      const newAnswers = [...state.answers, points];
      if (state.current + 1 >= questions.length) {
        const total = newAnswers.reduce((a, b) => a + b, 0);
        setState({ score: total, step: "result", selected: null, answers: newAnswers });
      } else {
        setState({ answers: newAnswers, current: state.current + 1, selected: null });
      }
    }, 380);
  }

  function restart() {
    setState({ step: "quiz", current: 0, answers: [], selected: null, score: 0 });
  }

  // ─── RENDER ───────────────────────────────────────────────
  function render() {
    const app = document.getElementById("app");
    const progress = ((state.current + 1) / questions.length) * 100;
    const profile = getProfile(state.score);

    if (state.step === "quiz") {
      const q = questions[state.current];
      app.innerHTML = `
        <div class="progress-label">Question ${state.current + 1} sur ${questions.length}</div>
        <div class="progress-track">
          <div class="progress-fill" style="width:${progress}%"></div>
        </div>
        <h2 class="question-title">${q.question}</h2>
        <p class="question-sub">Choisis la réponse qui te correspond le plus</p>
        <div class="options">
          ${q.options.map((opt, idx) => `
            <button
              class="option-btn ${state.selected !== null && state.selected !== idx ? 'faded' : ''} ${state.selected === idx ? 'selected' : ''}"
              onclick="handleSelect(${opt.points}, ${idx})"
            >${opt.text}</button>
          `).join('')}
        </div>
      `;
    } else {
      app.innerHTML = `
        <div style="text-align:center; margin-bottom:40px;">
          <span class="profile-badge">Ton profil</span>
          <h2 class="profile-title">${profile.title}</h2>
          <p class="profile-tagline">${profile.tagline}</p>
        </div>

        <div class="result-card">
          <p class="card-desc">${profile.description}</p>
          <div class="card-bonne-nouvelle">${profile.bonneNouvelle}</div>
        </div>

        <div class="result-card">
          <p class="card-label">Tes priorités</p>
          ${profile.priorities.map(item => `
            <div class="priority-item">
              <span class="priority-check">✅</span>
              <span>${item}</span>
            </div>
          `).join('')}
        </div>

        <div class="result-card-dark">
          <p class="card-label-orange">Ton prochain objectif</p>
          <p class="objectif-text">${profile.objectif}</p>
          <div class="suite-divider">
            <p class="suite-text">${profile.suite}</p>
          </div>
        </div>

        <button class="restart-btn" onclick="restart()">Refaire le quiz</button>
        <p class="footer-sig">Par Anissa · Nistoofly · @nistoofly</p>
      `;
    }
  }

  render();
</script>
</body>
</html>
